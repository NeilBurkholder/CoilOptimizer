<!-- File: LayoutView.xaml -->
<UserControl x:Class="CoilOptimizer.UI.LayoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CoilOptimizer.UI"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6"
                    VerticalAlignment="Center">
            <ToggleButton Content="Scale mode"
                          IsChecked="{Binding ScaleEnabled, Mode=TwoWay}"
                          Padding="8,2" Margin="0,0,6,0"/>
            <ToggleButton Content="Manual edit"
                          IsChecked="{Binding EditMode, Mode=TwoWay}"
                          Padding="8,2" Margin="0,0,12,0"/>
            <TextBlock Text="Fit" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <Slider Width="180" VerticalAlignment="Center"
                    Minimum="{Binding ZoomMin}" Maximum="{Binding ZoomMax}"
                    Value="{Binding Zoom, Mode=TwoWay}"
                    IsEnabled="{Binding ZoomEnabled}"
                    TickFrequency="0.05" IsSnapToTickEnabled="False"/>
            <TextBlock Text="1:1" VerticalAlignment="Center" Margin="4,0,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" x:Name="Scroller"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      SizeChanged="Scroller_SizeChanged">

            <Grid x:Name="Surface"
                  Width="{Binding BaseWidth}"
                  Height="{Binding BaseHeight}"
                  Background="{Binding FallOffBrush}"
                  MouseLeftButtonDown="Surface_MouseLeftButtonDown"
                  MouseMove="Surface_MouseMove"
                  MouseLeftButtonUp="Surface_MouseLeftButtonUp">

                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding ScaleX}" ScaleY="{Binding ScaleY}" />
                </Grid.LayoutTransform>

                <!-- offcut (gap) highlight -->
                <Canvas IsHitTestVisible="False">
                    <Rectangle Canvas.Left="{Binding GapX}" Canvas.Top="{Binding GapY}"
                               Width="{Binding GapW}" Height="{Binding GapH}"
                               Fill="{Binding GapBrush}"
                               Visibility="{Binding GapVisibility}">
                        <Rectangle.ToolTip>
                            <ToolTip Content="{Binding GapLabel}" />
                        </Rectangle.ToolTip>
                    </Rectangle>
                </Canvas>

                <!-- parts (wheat) -->
                <ItemsControl ItemsSource="{Binding Shapes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left"   Value="{Binding X}" />
                            <Setter Property="Canvas.Top"    Value="{Binding Y}" />
                            <Setter Property="Canvas.ZIndex" Value="{Binding ZIndex}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="{Binding Width}" Height="{Binding Height}" Tag="{Binding}"
                                  ToolTip="{Binding Label}" ClipToBounds="True">
                                <Rectangle Fill="{Binding Fill}" Stroke="#80000000"
                                    StrokeThickness="{Binding DataContext.HairlineThickness,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <!-- inverse transform keeps text constant + undistorted -->
                                <TextBlock Text="{Binding Label}" IsHitTestVisible="False"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="11" RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <ScaleTransform
                                            ScaleX="{Binding DataContext.InvScaleX,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            ScaleY="{Binding DataContext.InvScaleY,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- slits (horizontal black) -->
                <ItemsControl ItemsSource="{Binding SlitLines}" IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                  X2="{Binding X2}" Y2="{Binding Y2}"
                                  Stroke="{Binding DataContext.SlitBrush,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  StrokeThickness="{Binding DataContext.SlitThickness,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- shears (vertical red) -->
                <ItemsControl ItemsSource="{Binding ShearLines}" IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                  X2="{Binding X2}" Y2="{Binding Y2}"
                                  Stroke="{Binding DataContext.ShearBrush,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  StrokeThickness="{Binding DataContext.ShearThickness,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>