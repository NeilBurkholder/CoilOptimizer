<!-- File: LayoutView.xaml -->
<UserControl x:Class="CoilOptimizer.UI.LayoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CoilOptimizer.UI"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="6"
                    VerticalAlignment="Center">
            <ToggleButton Content="Scale mode"
                          IsChecked="{Binding ScaleEnabled, Mode=TwoWay}"
                          Padding="8,2" Margin="0,0,6,0"/>
            <ToggleButton Content="Manual edit"
                          IsChecked="{Binding EditMode, Mode=TwoWay}"
                          Padding="8,2" Margin="0,0,12,0"/>
            <TextBlock Text="Fit" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <!-- Slider stays enabled in both modes -->
            <Slider Width="180" VerticalAlignment="Center"
                    Minimum="{Binding ZoomMin}" Maximum="{Binding ZoomMax}"
                    Value="{Binding Zoom, Mode=TwoWay}"
                    TickFrequency="0.05" IsSnapToTickEnabled="False"/>
            <TextBlock Text="1:1" VerticalAlignment="Center" Margin="4,0,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" x:Name="Scroller"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      SizeChanged="Scroller_SizeChanged">
            <Grid x:Name="Host" Width="{Binding SurfacePixelWidth}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="15" />
                    <!-- pattern handles -->
                    <RowDefinition Height="15" />
                    <!-- column handles  -->
                    <RowDefinition Height="*"  />
                    <!-- coil surface     -->
                </Grid.RowDefinitions>

                <!-- Pattern handles (top, darker blue) -->
                <Canvas Grid.Row="0" Background="Transparent"
                MouseLeftButtonDown="PatternHandle_Down">
                    <ItemsControl ItemsSource="{Binding PatternHandles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top"  Value="0" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="{Binding Width}" Height="15" Tag="{Binding}"
                                Background="{Binding DataContext.PatternHandleBrush,
                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                BorderBrush="White" BorderThickness="0.5"
                                ToolTip="{Binding Label}" Cursor="SizeAll" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>

                <!-- Column handles (blue) -->
                <Canvas Grid.Row="1" Background="Transparent"
                MouseLeftButtonDown="ColumnHandle_Down">
                    <ItemsControl ItemsSource="{Binding ColumnHandles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top"  Value="0" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="{Binding Width}" Height="15" Tag="{Binding}"
                                Background="{Binding DataContext.ColumnHandleBrush,
                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                BorderBrush="White" BorderThickness="0.5"
                                ToolTip="{Binding Label}" Cursor="SizeAll" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>

                <!-- pattern-boundary lines through the handle bands (rows 0-1) -->
                <Canvas Grid.Row="0" Grid.RowSpan="2" IsHitTestVisible="False">
                    <ItemsControl ItemsSource="{Binding HandleBoundaryLines}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Line X1="{Binding X1}" Y1="{Binding Y1}"
                      X2="{Binding X2}" Y2="{Binding Y2}"
                      Stroke="{Binding DataContext.PatternBoundaryBrush,
                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                      StrokeThickness="3" SnapsToDevicePixels="True" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>

                <Grid x:Name="Surface" Grid.Row="2"
                  Width="{Binding BaseWidth}"
                  Height="{Binding BaseHeight}"
                  HorizontalAlignment="Left" VerticalAlignment="Top"
                  Background="{Binding FallOffBrush}"
                  MouseLeftButtonDown="Surface_MouseLeftButtonDown"
                  MouseMove="Surface_MouseMove"
                  MouseLeftButtonUp="Surface_MouseLeftButtonUp">

                    <Grid.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding ScaleX}" ScaleY="{Binding ScaleY}" />
                    </Grid.LayoutTransform>

                    <!-- offcut highlight -->
                    <Canvas IsHitTestVisible="False">
                        <Rectangle Canvas.Left="{Binding GapX}" Canvas.Top="{Binding GapY}"
                               Width="{Binding GapW}" Height="{Binding GapH}"
                               Fill="{Binding GapBrush}"
                               Visibility="{Binding GapVisibility}">
                            <Rectangle.ToolTip>
                                <ToolTip Content="{Binding GapLabel}" />
                            </Rectangle.ToolTip>
                        </Rectangle>
                    </Canvas>

                    <!-- parts -->
                    <ItemsControl ItemsSource="{Binding Shapes}" ClipToBounds="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas ClipToBounds="False"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left"   Value="{Binding X}" />
                                <Setter Property="Canvas.Top"    Value="{Binding Y}" />
                                <Setter Property="Canvas.ZIndex" Value="{Binding ZIndex}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- NOTE: no ClipToBounds, so the (visually tiny) label
                                 is never clipped by narrow strips. -->
                                <Grid Width="{Binding Width}" Height="{Binding Height}" ClipToBounds="False"
                                  Tag="{Binding}" ToolTip="{Binding Label}">
                                    <Rectangle Fill="{Binding Fill}" Stroke="#FF000000"
                                    StrokeThickness="{Binding DataContext.HairlineThickness,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                    <TextBlock Text="{Binding Label}" IsHitTestVisible="False" Padding="0" Margin="0" MinHeight="1"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" LineStackingStrategy="BlockLineHeight" LineHeight="1" 
                                           FontSize="11" RenderTransformOrigin="0.5,0.6">
                                        <TextBlock.RenderTransform>
                                            <ScaleTransform
                                            ScaleX="{Binding DataContext.InvScaleX,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            ScaleY="{Binding DataContext.InvScaleY,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- slits -->
                    <ItemsControl ItemsSource="{Binding SlitLines}" IsHitTestVisible="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                  X2="{Binding X2}" Y2="{Binding Y2}"
                                  Stroke="{Binding DataContext.SlitBrush,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  StrokeThickness="{Binding DataContext.SlitThickness,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- shears (surface) -->
                    <ItemsControl ItemsSource="{Binding ShearLines}" IsHitTestVisible="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}">
                                    <Line.Style>
                                        <Style TargetType="Line">
                                            <!-- default: regular shear (red) -->
                                            <Setter Property="Stroke"
                                Value="{Binding DataContext.ShearBrush,
                                    RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                            <Setter Property="StrokeThickness" Value="{Binding DataContext.ShearThickness, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPatternBoundary}" Value="True">
                                                    <Setter Property="Stroke"
                                        Value="{Binding DataContext.PatternBoundaryBrush,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                    <Setter Property="StrokeThickness" Value="{Binding DataContext.ShearPatternThickness, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Line.Style>
                                </Line>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>